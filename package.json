{
  "name": "@inferagraph/log-analytics-datasource",
  "version": "0.1.1",
  "type": "module",
  "description": "Azure Log Analytics datasource for InferaGraph (KQL via @azure/monitor-query or APIM)",
  "repository": { "type": "git", "url": "git+https://github.com/inferagraph/log-analytics-datasource.git" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "packageManager": "pnpm@10.33.2",
  "license": "MIT",
  "peerDependencies": {
    "@inferagraph/core": "^0.1.0"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@azure/monitor-query": "^1.3.0"
  },
  "devDependencies": {
    "@inferagraph/core": "^0.1.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.1.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
